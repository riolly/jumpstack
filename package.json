    "@orpc/tanstack-query": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
